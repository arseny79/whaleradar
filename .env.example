# PostgreSQL connection string (e.g., postgresql://user:pass@host:5432/dbname)
DATABASE_URL=

# Telegram Bot API token from @BotFather
TELEGRAM_BOT_TOKEN=

# Telegram Payments provider token (from @BotFather → Payments)
TELEGRAM_PROVIDER_TOKEN=

# Polymarket API base URL (e.g., https://clob.polymarket.com)
POLYMARKET_API_BASE_URL=

# Admin panel HTTP Basic Auth credentials
ADMIN_USERNAME=
ADMIN_PASSWORD=

# Public base URL of this application (e.g., https://whaleradar.example.com)
APP_BASE_URL=

# Node environment: "development" | "production" (default: "development")
NODE_ENV=development
